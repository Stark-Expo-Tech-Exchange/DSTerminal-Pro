{
  "critical_files": {
    "action": "alert_and_restore",
    "backup_source": "baseline",
    "notify": true,
    "severity_threshold": "CRITICAL"
  },
  "suspicious_executables": {
    "action": "quarantine",
    "notify": true,
    "severity_threshold": "HIGH"
  },
  "config_changes": {
    "action": "alert",
    "notify": true,
    "severity_threshold": "MEDIUM"
  },
  "unauthorized_access": {
    "action": "block_and_alert",
    "notify": true,
    "severity_threshold": "HIGH"
  },
  "log_files": {
    "action": "alert",
    "notify": false,
    "severity_threshold": "LOW"
  }
}